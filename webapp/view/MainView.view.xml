<mvc:View
  controllerName="com.excel.excelupload.controller.MainView"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:l="sap.ui.layout"
  xmlns:core="sap.ui.core"
  xmlns:u="sap.ui.unified"
  displayBlock="true"
>

  <App id="app1">
    <pages>
      <Page
        id="mainPage"
        title="Excel Upload And Display"
        enableScrolling="true"
      >

        <headerContent>
          <Button id="_IDGenButton1"
            icon="sap-icon://refresh"
            tooltip="Reset"
            press="onReset"
            type="Transparent"
          />
        </headerContent>

        <content>
          <VBox id="_IDGenVBox" class="sapUiMediumMargin">

            <!-- ====== UPLOAD PANEL ====== -->
            <Panel id="_IDGenPanel" width="100%" class="sapUiMediumMarginBottom">
              <headerToolbar>
                <Toolbar id="_IDGenToolbar">
                  <Title id="_IDGenTitle" text="Upload Excel File" level="H4" />
                </Toolbar>
              </headerToolbar>
              <content>
                <VBox id="_IDGenVBox1" alignItems="Center" class="sapUiMediumMargin">

                  <core:Icon id="_IDGenIcon"
                    src="sap-icon://excel-attachment"
                    size="3rem"
                    color="#0070f2"
                    class="sapUiSmallMarginBottom"
                  />

                  <Title id="_IDGenTitle1"
                    text="Select your Excel or CSV file"
                    level="H4"
                    class="sapUiSmallMarginBottom"
                  />

                  <Text id="_IDGenText"
                    text="Supported: .xlsx  .xls  .csv  |  Max: 10MB"
                    class="sapUiSmallMarginBottom"
                  />

                  <u:FileUploader
                    id="fileUploader"
                    width="300px"
                    buttonOnly="false"
                    buttonText="Choose File"
                    change="onFileChange"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom"
                  />

                  <Button
                    id="uploadBtn"
                    text="Upload and Parse"
                    type="Emphasized"
                    icon="sap-icon://upload"
                    press="onUploadPress"
                    enabled="false"
                    class="sapUiSmallMarginTop"
                  />

                </VBox>

                <MessageStrip
                  id="fileInfoStrip"
                  text="No file selected"
                  type="Information"
                  showIcon="true"
                  visible="false"
                  class="sapUiSmallMargin"
                />

                <MessageStrip
                  id="errorStrip"
                  text=""
                  type="Error"
                  showIcon="true"
                  visible="false"
                  class="sapUiSmallMargin"
                />

                <ProgressIndicator
                  id="uploadProgress"
                  visible="false"
                  percentValue="0"
                  displayValue="Processing..."
                  state="Information"
                  class="sapUiSmallMargin"
                />

              </content>
            </Panel>

            <!-- ====== STATS PANEL ====== -->
            <Panel
              id="statsPanel"
              visible="false"
              width="100%"
              class="sapUiMediumMarginBottom"
            >
              <headerToolbar>
                <Toolbar id="_IDGenToolbar1">
                  <Title id="_IDGenTitle2" text="File Summary" level="H4" />
                </Toolbar>
              </headerToolbar>
              <content>
                <HBox id="_IDGenHBox"
                  justifyContent="SpaceAround"
                  wrap="Wrap"
                  class="sapUiMediumMargin"
                >

                  <VBox id="_IDGenVBox2" alignItems="Center" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                    <core:Icon id="_IDGenIcon1"
                      src="sap-icon://list"
                      size="2rem"
                      color="#0070f2"
                      class="sapUiSmallMarginBottom"
                    />
                    <Title id="totalRowsText" text="0" level="H2" />
                    <Label id="_IDGenLabel" text="Total Rows" />
                  </VBox>

                  <VBox id="_IDGenVBox3" alignItems="Center" class="sapUiMediumMarginEnd sapUiMediumMarginBottom">
                    <core:Icon id="_IDGenIcon2"
                      src="sap-icon://table-column"
                      size="2rem"
                      color="#e76500"
                      class="sapUiSmallMarginBottom"
                    />
                    <Title id="totalColsText" text="0" level="H2" />
                    <Label id="_IDGenLabel1" text="Total Columns" />
                  </VBox>

                  <VBox id="_IDGenVBox4" alignItems="Center" class="sapUiMediumMarginBottom">
                    <core:Icon id="_IDGenIcon3"
                      src="sap-icon://document-text"
                      size="2rem"
                      color="#188918"
                      class="sapUiSmallMarginBottom"
                    />
                    <Title id="sheetNameText" text="-" level="H4" />
                    <Label id="_IDGenLabel2" text="Sheet Name" />
                  </VBox>

                </HBox>
              </content>
            </Panel>

            <!-- ====== TABLE PANEL ====== -->
            <Panel
              id="tablePanel"
              visible="false"
              width="100%"
            >
              <headerToolbar>
                <OverflowToolbar id="_IDGenOverflowToolbar">
                  <Title id="tableTitle" text="Excel Data" level="H4" />
                  <ToolbarSpacer id="_IDGenToolbarSpacer" />
                  <SearchField
                    id="searchField"
                    placeholder="Search..."
                    liveChange="onSearch"
                    width="200px"
                  />
                  <Button id="_IDGenButton2"
                    text="Export CSV"
                    icon="sap-icon://download"
                    type="Transparent"
                    press="onExportCSV"
                  />
                  <Button id="_IDGenButton3"
                    icon="sap-icon://delete"
                    tooltip="Delete Selected"
                    press="onDeleteRows"
                    type="Transparent"
                  />
                </OverflowToolbar>
              </headerToolbar>
              <content>
                <Table
                  id="excelTable"
                  mode="MultiSelect"
                  growing="true"
                  growingThreshold="20"
                  alternateRowColors="true"
                  width="100%"
                  noDataText="No data. Please upload an Excel file."
                >
                  <columns />
                  <items  />
                </Table>
              </content>
            </Panel>

          </VBox>
        </content>

        <footer>
          <Toolbar id="_IDGenToolbar2">
            <ToolbarSpacer id="_IDGenToolbarSpacer1" />
            <Text id="_IDGenText1" text="Excel Upload App | SAP UI5" />
            <ToolbarSpacer id="_IDGenToolbarSpacer2" />
          </Toolbar>
        </footer>

      </Page>
    </pages>
  </App>

</mvc:View>